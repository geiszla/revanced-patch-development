.idea/
*.iml
.vscode/
!.vscode/extensions.json

# Environment and credentials (may contain GitHub PAT)
.env
patches/gradle.properties
patches/local.properties

# OS
.DS_Store
Thumbs.db

# Signing keys
*.keystore
*.jks
*.pk8
*.pem
